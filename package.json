{
	"name": "my-ap",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:emulator": "vite dev --mode emulator",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"fix": "biome check --write",
		"emulate": "firestack emulate",
		"emulate:local": "node ../firestack/dist/main.js emulate",
		"test": "bunx playwright test",
		"test:ui": "bunx playwright test --ui",
		"test:unit": "vitest",
		"setup:admin": "bun scripts/setup-admin-user.ts",
		"upload-secrets": "bun scripts/upload-secrets-to-github.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@fission-ai/openspec": "^1.3.1",
		"@playwright/test": "^1.59.1",
		"@snorreks/firestack": "^0.0.48",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"@types/bun": "^1.3.13",
		"@types/canvas-confetti": "^1.9.0",
		"firebase-tools": "^15.16.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.3",
		"vercel": "^52.2.1",
		"vite": "^8.0.10"
	},
	"dependencies": {
		"@dicebear/collection": "^9.4.2",
		"@dicebear/core": "^9.4.2",
		"@genkit-ai/googleai": "^1.28.0",
		"canvas-confetti": "^1.9.4",
		"fast-average-color": "^9.5.2",
		"firebase": "^12.12.1",
		"genkit": "^1.33.0"
	}
}
